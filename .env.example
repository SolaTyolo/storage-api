# cp .env.example .env

HTTP_ADDR=:8080
# ENV=production
# API_KEY required when ENV=production
LOG_LEVEL=info
LOG_FORMAT=text
# LOG_FORMAT=json
STORAGE_CONFIG_PATH=config/storage.yaml
STORAGE_DEFAULT_ENGINE=rustfs

# API_KEY=change-me-in-production
# API_KEYS=key-a,key-b
# JWT_SECRET=your-supabase-jwt-secret
# ALLOW_PRESIGNED_UPLOAD=true
# AUTH_DOWNLOAD_MODE=proxy
# AUTHZ_HTTP_URL=http://localhost:9002/authz
# AUTHZ_HTTP_TIMEOUT_SEC=5
# AUTHZ_BYPASS_SERVICE_ROLE=true
# AUTHZ_BYPASS_API_KEY=true
# PREVIEW_ASYNC=false
# PREVIEW_JOB_TTL_SEC=900
# SIDECAR_API_TOKEN=
PRESIGN_EXPIRES_SEC=3600
PUBLIC_PRESIGN_EXPIRES_SEC=900
TRANSFORM_BACKEND=imgproxy
# internal | imgproxy
TRANSFORM_MAX_EDGE=4096
IMGPROXY_BASE_URL=http://localhost:8081
IMGPROXY_INSECURE=true
# IMGPROXY_KEY=
# IMGPROXY_SALT=

GOTENBERG_URL=http://localhost:3000
POPPLER_WORKER_URL=http://localhost:8090

FFMPEG_PATH=ffmpeg
