# cp .env.example .env

HTTP_ADDR=:8080
DATABASE_URL=postgres://storage:storage@localhost:5432/storage?sslmode=disable

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin
S3_BUCKET=uploads
S3_USE_PATH_STYLE=true

PRESIGN_EXPIRES_SEC=3600
UPLOAD_SIGNING_SECRET=change-me-in-production
TRANSFORM_BACKEND=imgproxy
# internal | imgproxy
TRANSFORM_MAX_EDGE=4096
IMGPROXY_BASE_URL=http://localhost:8081
IMGPROXY_INSECURE=true

GOTENBERG_URL=http://localhost:3000
POPPLER_WORKER_URL=http://localhost:8090

FFMPEG_PATH=ffmpeg
